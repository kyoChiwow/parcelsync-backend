<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f7ff;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
      }
      .header {
        background-color: #4a90e2;
        padding: 30px;
        text-align: center;
        color: white;
      }
      .content {
        padding: 40px;
        text-align: center;
        color: #333;
      }
      .otp-container {
        background: #f0f4f8;
        border-radius: 12px;
        padding: 20px;
        margin: 25px 0;
        display: inline-block;
        width: 80%;
      }
      .otp-code {
        font-size: 32px;
        font-weight: bold;
        letter-spacing: 8px;
        color: #4a90e2;
      }
      .footer {
        padding: 20px;
        text-align: center;
        font-size: 12px;
        color: #888;
        background: #fafafa;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        color: white;
        background-color: #4a90e2;
        border-radius: 5px;
        text-decoration: none;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>ParcelSync</h1>
      </div>
      <div class="content">
        <h2>Verify Your Account</h2>
        <p>Hi <%= name %>,</p>
        <p>
          Use the following One-Time Password (OTP) to complete your
          verification. This code is valid for 2 minutes.
        </p>

        <div class="otp-container">
          <span class="otp-code"><%= otp %></span>
        </div>

        <p style="font-size: 14px; color: #666">
          If you didn't request this, you can safely ignore this email.
        </p>
      </div>
      <div class="footer">
        <p>&copy; 2024 ParcelSync Team. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        background-color: #f9fafb;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        width: 100%;
        table-layout: fixed;
        background-color: #f9fafb;
        padding-bottom: 40px;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        margin-top: 40px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      }
      .header {
        background-color: #1a56db;
        padding: 40px 20px;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .content {
        padding: 40px;
        color: #374151;
        line-height: 1.6;
      }
      .content h2 {
        color: #111827;
        font-size: 20px;
        margin-bottom: 16px;
      }
      .content p {
        margin-bottom: 24px;
        font-size: 16px;
      }
      .btn-container {
        text-align: center;
        margin: 32px 0;
      }
      .btn {
        background-color: #1a56db;
        color: #ffffff !important;
        padding: 14px 32px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        display: inline-block;
        transition: background-color 0.3s ease;
      }
      .expiry-note {
        font-size: 13px;
        color: #6b7280;
        text-align: center;
        margin-top: 24px;
      }
      .footer {
        padding: 32px;
        background-color: #f3f4f6;
        text-align: center;
        color: #9ca3af;
        font-size: 12px;
      }
      .footer p {
        margin: 4px 0;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <h1>ParcelSync</h1>
        </div>
        <div class="content">
          <h2>Password Reset Request</h2>
          <p>Hi <strong><%= name %></strong>,</p>
          <p>
            We received a request to reset the password for your account. No
            worries, it happens to the best of us!
          </p>
          <p>
            Click the button below to set up a new password. This link is valid
            for <strong>10 minutes</strong>.
          </p>

          <div class="btn-container">
            <a href="<%= resetLink %>" class="btn">Reset My Password</a>
          </div>

          <p>
            If you didn't request this change, you can safely ignore this email.
            Your password will remain unchanged.
          </p>

          <div class="expiry-note">Link expires in 10 minutes.</div>
        </div>
        <div class="footer">
          <p>&copy; 2024 ParcelSync Inc. All rights reserved.</p>
          <p>Dhaka, Bangladesh</p>
        </div>
      </div>
    </div>
  </body>
</html>
